<view class="community-page {{timelineExpanded ? 'page-locked' : ''}}">

  <!-- 顶部栏：区域 + 排序切换 -->
  <view class="top-bar">
    <view class="district-bar" bindtap="onDistrictTap" wx:if="{{districtName}}">
      <image class="district-icon" src="/images/icon-location.svg" />
      <text class="district-name">{{districtName}}</text>
      <image class="district-arrow" src="/images/icon-arrow-right.svg" />
    </view>
    <view class="sort-toggle" catchtap="">
      <view class="sort-item {{sortBy === 'photoDate' ? 'active' : ''}}" catchtap="onSortToggle" data-sort="photoDate">拍摄时间</view>
      <view class="sort-item {{sortBy === 'createTime' ? 'active' : ''}}" catchtap="onSortToggle" data-sort="createTime">上传时间</view>
      <view class="sort-item {{sortBy === 'commentCount' ? 'active' : ''}}" catchtap="onSortToggle" data-sort="commentCount">评论数</view>
      <view class="sort-item {{sortBy === 'likeCount' ? 'active' : ''}}" catchtap="onSortToggle" data-sort="likeCount">点赞数</view>
    </view>
  </view>

  <!-- 统计摘要（仅时间轴模式） -->
  <view class="stats-bar" wx:if="{{statTotal > 0 && !isRankMode}}">
    <text class="stats-text">共 {{statTotal}} 张照片 · 包含 {{statDays}} 个日期 · {{statBusiestDay}}最活跃</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{isEmpty && !loading}}">
    <view class="empty-timeline">
      <view class="empty-line"></view>
      <view class="empty-dot"></view>
    </view>
    <text class="empty-text">这片区域还没有时光记忆，去上传第一张吧</text>
  </view>

  <!-- ===== 排行模式（评论数/点赞数排序） ===== -->
  <view class="rank-list" wx:if="{{isRankMode && !isEmpty}}">
    <view class="rank-item" wx:for="{{rankList}}" wx:key="id" bindtap="onPhotoTap" data-id="{{item.id}}">
      <view class="rank-index-col">
        <text class="rank-num {{item.rank <= 3 ? 'top' : ''}}">{{item.rank}}</text>
      </view>
      <view class="rank-card">
        <image class="rank-image" src="{{item.thumbnailUrl || item.imageUrl}}" mode="aspectFill" lazy-load />
        <view class="rank-info">
          <view class="rank-user">
            <image class="rank-avatar" src="{{item.avatarUrl || '/images/icon-user.svg'}}" />
            <text class="rank-nickname">{{item.nickname || '匿名用户'}}</text>
          </view>
          <view class="rank-meta">
            <text class="rank-location" wx:if="{{item.locationName}}">{{item.locationName}}</text>
          </view>
          <view class="rank-bottom">
            <view class="rank-counts">
              <view class="rank-badge comment" wx:if="{{item.commentCount > 0}}">
                <image class="rank-badge-icon" src="/images/icon-message.svg" />
                <text class="rank-badge-num">{{item.commentCount}}</text>
              </view>
              <view class="rank-badge like" wx:if="{{item.likeCount > 0}}">
                <image class="rank-badge-icon" src="/images/icon-heart-fill.svg" />
                <text class="rank-badge-num">{{item.likeCount}}</text>
              </view>
              <view class="rank-badge zero" wx:if="{{(sortBy === 'commentCount' && item.commentCount === 0) || (sortBy === 'likeCount' && item.likeCount === 0)}}">
                <text class="rank-badge-num">{{sortBy === 'commentCount' ? '暂无评论' : '暂无点赞'}}</text>
              </view>
            </view>
            <text class="rank-date">{{item.photoDate}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 时间轴内容区（仅时间轴模式） -->
  <view class="timeline" wx:if="{{!isEmpty && !isRankMode}}">
    <block wx:for="{{groups}}" wx:key="dateKey" wx:for-index="gi">
      <view class="tl-group" id="date-{{item.dateId}}">

        <!-- 日期标题行 -->
        <view class="tl-date-row">
          <view class="tl-axis-col tl-axis-tap" bindtap="onAxisTap">
            <view class="tl-line tl-line-top {{gi === 0 ? 'hidden' : ''}}"></view>
            <view class="tl-dot-date {{item.isToday || activeDate === item.dateKey ? 'active' : ''}}"></view>
            <view class="tl-line tl-line-bottom"></view>
          </view>
          <view class="tl-date-content">
            <text class="tl-date-text {{item.isToday ? 'today' : ''}}">{{item.dateLabel}}</text>
            <text class="tl-date-count">({{item.photoCount}}张)</text>
          </view>
        </view>

        <!-- 照片卡片列表 -->
        <view class="tl-card-row" wx:for="{{item.photos}}" wx:for-item="photo" wx:key="id" id="photo-{{photo.id}}">
          <view class="tl-axis-col tl-axis-tap" bindtap="onAxisTap">
            <view class="tl-line tl-line-full"></view>
            <view class="tl-dot-photo {{activePhotoId == photo.id ? 'active' : ''}}"></view>
          </view>
          <view class="tl-card-wrap">
            <view class="tl-connector"></view>
            <view class="photo-card" bindtap="onPhotoTap" data-id="{{photo.id}}">
              <image class="card-image" src="{{photo.thumbnailUrl || photo.imageUrl}}" mode="widthFix" lazy-load />
              <view class="card-info">
                <view class="card-user">
                  <image class="card-avatar" src="{{photo.avatarUrl || '/images/icon-user.svg'}}" />
                  <text class="card-nickname">{{photo.nickname || '匿名用户'}}</text>
                </view>
                <view class="card-meta">
                  <text class="card-location" wx:if="{{photo.locationName}}">{{photo.locationName}}</text>
                  <text class="card-date">{{photo.photoDate}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

      </view>
    </block>

    <!-- 轴线终止 -->
    <view class="tl-end">
      <view class="tl-axis-col">
        <view class="tl-line tl-line-top"></view>
        <view class="tl-dot-end"></view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="loading-tip end" wx:if="{{!hasMore && !isEmpty && !loading}}">
    <text>没有更多了</text>
  </view>

  <!-- 时间轴展开面板遮罩（仅时间轴模式） -->
  <view class="panel-mask {{timelineExpanded ? 'show' : ''}}" wx:if="{{!isRankMode}}" bindtap="onPanelMaskTap" catchtouchmove="preventTouchMove"></view>

  <!-- 时间轴展开面板（仅时间轴模式） -->
  <view class="panel-drawer {{timelineExpanded ? 'show' : ''}}" wx:if="{{!isRankMode}}" catchtouchmove="onPanelTouchMove">
    <!-- 右侧轴线装饰 -->
    <view class="panel-axis-line"></view>
    <!-- 顶部渐变 -->
    <view class="panel-fade-top"></view>
    <!-- 日期列表 -->
    <scroll-view
      class="panel-scroll"
      scroll-y
      enhanced
      show-scrollbar="{{false}}"
      scroll-into-view="{{panelScrollTo}}"
      scroll-with-animation
    >
      <view class="panel-list">
        <block wx:for="{{panelDates}}" wx:key="key">
          <!-- 月份分隔 -->
          <view class="panel-month" wx:if="{{item.type === 'month'}}">
            <view class="panel-month-line"></view>
            <text class="panel-month-text">{{item.label}}</text>
            <view class="panel-month-line"></view>
          </view>
          <!-- 日期项 -->
          <view
            class="panel-date-item {{activeDate === item.dateKey ? 'active' : ''}} {{item.isToday ? 'today' : ''}}"
            wx:if="{{item.type === 'date'}}"
            id="{{item.key}}"
            bindtap="onPanelDateTap"
            data-date="{{item.dateKey}}"
          >
            <view class="panel-dot {{activeDate === item.dateKey ? 'active' : ''}}"></view>
            <view class="panel-date-info">
              <text class="panel-date-main">{{item.shortLabel}}</text>
              <text class="panel-date-sub">{{item.weekDay}}</text>
            </view>
            <text class="panel-date-count">{{item.photoCount}}张</text>
          </view>
        </block>
      </view>
    </scroll-view>
    <!-- 底部渐变 -->
    <view class="panel-fade-bottom"></view>
  </view>

</view>
