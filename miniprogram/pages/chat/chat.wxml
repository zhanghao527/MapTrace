<view class="chat-page">
  <scroll-view class="msg-list" scroll-y scroll-with-animation scroll-anchoring
    scroll-into-view="{{scrollIntoView}}" upper-threshold="120"
    bindscrolltoupper="onScrollToUpper"
    style="height: {{messageListHeight}}px;">

    <view class="load-more" wx:if="{{loading}}"><text>加载中...</text></view>
    <view class="load-more" wx:if="{{!hasMore && messages.length > 30}}"><text>没有更多消息了</text></view>

    <block wx:for="{{renderMessages}}" wx:key="renderKey">
      <!-- 时间分隔 -->
      <view wx:if="{{item.type === 'time'}}" class="chat-time">
        <text class="chat-time-text">{{item.label}}</text>
      </view>

      <!-- 对方消息：头像在左，白色气泡 -->
      <view wx:elif="{{item.type === 'message' && !item.isMine}}" class="msg-row other" id="msg-{{item.messageId}}"
        bindlongpress="onMessageLongPress" data-id="{{item.messageId}}" data-is-mine="{{false}}">
        <image class="msg-avatar" src="{{otherAvatarUrl || '/images/icon-user.svg'}}" mode="aspectFill" />
        <view class="msg-bubble bubble-other">
          <text selectable space="nbsp">{{item.content}}</text>
        </view>
      </view>

      <!-- 我的消息：绿色气泡，头像在右 -->
      <view wx:elif="{{item.type === 'message' && item.isMine}}" class="msg-row mine" id="msg-{{item.messageId}}"
        bindlongpress="onMessageLongPress" data-id="{{item.messageId}}" data-is-mine="{{true}}">
        <view class="msg-mine-content">
          <view class="msg-bubble bubble-mine">
            <text selectable space="nbsp">{{item.content}}</text>
          </view>
          <view class="msg-status" wx:if="{{item.sending || item.sendFail}}">
            <text class="msg-sending" wx:if="{{item.sending}}">发送中</text>
            <text class="msg-fail" wx:if="{{item.sendFail}}" bindtap="onResend" data-id="{{item.id}}">发送失败，点击重试</text>
          </view>
        </view>
        <image class="msg-avatar" src="{{myAvatarUrl || '/images/icon-user.svg'}}" mode="aspectFill" />
      </view>
    </block>

    <view class="msg-empty" wx:if="{{!messages.length && !loading}}">
      <text>暂无消息，开始你们的第一句对话吧</text>
    </view>
  </scroll-view>

  <!-- 底部输入栏 -->
  <view class="chat-input-bar" style="bottom: {{keyboardHeight}}px; padding-bottom: {{safeAreaBottom}}px;">
    <input class="chat-input"
      placeholder="输入消息..."
      placeholder-class="chat-placeholder"
      value="{{inputValue}}"
      bindinput="onInputChange"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      confirm-type="send"
      bindconfirm="onSend"
      adjust-position="{{false}}"
      cursor-spacing="24"
      bindkeyboardheightchange="onKeyboardHeight"
      maxlength="500" />
    <view class="chat-send {{inputValue ? 'active' : ''}}" bindtap="onSend">发送</view>
  </view>
</view>
