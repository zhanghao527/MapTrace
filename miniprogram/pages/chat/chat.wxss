page {
  background: #ededed;
}

.chat-page {
  min-height: 100%;
  background: #ededed;
}

.msg-list {
  padding: 24rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.load-more {
  text-align: center;
  padding: 12rpx 0 20rpx;
  color: #999;
  font-size: 24rpx;
}

/* 时间分隔 */
.chat-time {
  display: flex;
  justify-content: center;
  margin: 16rpx 0 24rpx;
}
.chat-time-text {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #999;
  background: rgba(0, 0, 0, 0.05);
}

/* 空状态 */
.msg-empty {
  text-align: center;
  padding: 180rpx 0;
  color: #bbb;
  font-size: 26rpx;
}

/* ========== 消息行 ========== */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

/* 对方消息：默认从左到右 */
.msg-row.other {
  justify-content: flex-start;
}

/* 我的消息：从右到左 */
.msg-row.mine {
  justify-content: flex-end;
}

/* 头像 */
.msg-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background: #dcdcdc;
}

/* 气泡通用 */
.msg-bubble {
  max-width: 500rpx;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-all;
  overflow-wrap: anywhere;
}

/* 对方气泡：白色，左侧有小尖角效果 */
.bubble-other {
  margin-left: 16rpx;
  background: #fff;
  color: #111;
}

/* 我的气泡：绿色，右侧 */
.msg-mine-content {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  max-width: 500rpx;
  margin-right: 16rpx;
}
.bubble-mine {
  background: #95ec69;
  color: #111;
}

/* 发送状态 */
.msg-status {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #999;
}
.msg-sending {
  display: inline-block;
}
.msg-fail {
  color: #ff4d4f;
}

/* ========== 底部输入栏 ========== */
.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  box-sizing: border-box;
  background: #f7f7f7;
  border-top: 1rpx solid #ddd;
  z-index: 100;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.chat-placeholder {
  color: #bbb;
}

.chat-send {
  margin-left: 16rpx;
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #b4b4b4;
  flex-shrink: 0;
  border-radius: 8rpx;
  background: #e0e0e0;
}

.chat-send.active {
  color: #fff;
  font-weight: 500;
  background: #07c160;
}
