<view class="container">

  <!-- ========== 状态1：未登录 ========== -->
  <view wx:if="{{!isLoggedIn}}" class="login-page">
    <view class="login-hero">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <image class="login-logo" src="/images/icon.png" mode="aspectFit" />
        <text class="login-app-name">地图时迹</text>
        <text class="login-slogan">用照片标记时间，用地图丈量记忆</text>
      </view>
    </view>

    <view class="login-features">
      <view class="feature-card">
        <view class="feature-icon-wrap">
          <image class="feature-svg" src="/images/icon-camera.svg" mode="aspectFit" />
        </view>
        <view class="feature-info">
          <text class="feature-title">随手记录</text>
          <text class="feature-desc">拍下城市角落的每一刻</text>
        </view>
      </view>
      <view class="feature-card">
        <view class="feature-icon-wrap">
          <image class="feature-svg" src="/images/icon-pin.svg" mode="aspectFit" />
        </view>
        <view class="feature-info">
          <text class="feature-title">地图足迹</text>
          <text class="feature-desc">在地图上浏览你的影像记忆</text>
        </view>
      </view>
      <view class="feature-card">
        <view class="feature-icon-wrap">
          <image class="feature-svg" src="/images/icon-clock.svg" mode="aspectFit" />
        </view>
        <view class="feature-info">
          <text class="feature-title">时光回溯</text>
          <text class="feature-desc">穿越时间线重温每段故事</text>
        </view>
      </view>
    </view>

    <view class="login-action">
      <view class="agreement-row" bindtap="onToggleAgreement">
        <view class="agreement-checkbox {{agreedPolicy ? 'checked' : ''}}">
          <text wx:if="{{agreedPolicy}}" class="check-icon">✓</text>
        </view>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" catchtap="onViewAgreement" data-type="user">《用户服务协议》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" catchtap="onViewAgreement" data-type="privacy">《隐私政策》</text>
      </view>
      <button class="login-btn {{agreedPolicy ? '' : 'login-btn-disabled'}}" bindtap="onLogin">
        <text class="login-btn-text">微信授权登录</text>
      </button>
    </view>
  </view>

  <!-- ========== 状态2+3：已登录（正常页面 + 弹窗引导） ========== -->
  <view wx:else>
    <view class="user-card">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/icon-user.svg'}}" mode="aspectFill" bindtap="onEditProfile" />
      <view class="user-main">
        <view class="user-info">
          <text class="nickname" bindtap="onEditProfile">{{userInfo.nickname || '微信用户'}}</text>
          <text class="user-summary" wx:if="{{userInfo.photoCount > 0}}">
            已上传 {{userInfo.photoCount || 0}} 张照片，足迹覆盖 {{userInfo.areaCount || 0}} 个区域
          </text>
          <text class="user-summary" wx:else>去地图上传第一张照片，开始记录你的城市足迹</text>
        </view>
        <view class="summary-grid">
          <view class="summary-item">
            <text class="summary-value">{{userInfo.photoCount || 0}}</text>
            <text class="summary-label">照片</text>
          </view>
          <view class="summary-item">
            <text class="summary-value">{{userInfo.areaCount || 0}}</text>
            <text class="summary-label">区域</text>
          </view>
          <view class="summary-item">
            <text class="summary-value">{{userInfo.likeCount || 0}}</text>
            <text class="summary-label">获赞</text>
          </view>
          <view class="summary-item" bindtap="onGoFollowList">
            <text class="summary-value">{{followCount.mutualCount || 0}}</text>
            <text class="summary-label">互关</text>
          </view>
        </view>
        <view class="recent-row" wx:if="{{userInfo.latestPhotoDate}}">
          <text class="recent-tag">最近记录</text>
          <text class="recent-date">{{userInfo.latestPhotoDate}}</text>
        </view>
      </view>
      <!-- 更多菜单按钮 -->
      <view class="more-btn" bindtap="onToggleMenu">
        <view class="more-line"></view>
        <view class="more-line"></view>
        <view class="more-line"></view>
      </view>
    </view>

    <!-- 菜单列表（可折叠） -->
    <view class="menu-list" wx:if="{{showMenu}}">
      <view class="menu-item" bindtap="onGoFollowList">
        <text class="menu-icon">👥</text>
        <text class="menu-text">我的关注</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onGoMessages">
        <text class="menu-icon">💬</text>
        <text class="menu-text">我的消息</text>
        <view class="menu-badge" wx:if="{{unreadCount > 0}}">
          <text>{{unreadCount > 99 ? '99+' : unreadCount}}</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onGoMyReports">
        <text class="menu-icon">🚩</text>
        <text class="menu-text">我的举报</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onGoMyViolations">
        <text class="menu-icon">⚠️</text>
        <text class="menu-text">我的违规</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" wx:if="{{isAdmin}}" bindtap="onGoAdminReports">
        <text class="menu-icon">🛡️</text>
        <text class="menu-text">举报处理台</text>
        <view class="menu-badge" wx:if="{{pendingReportCount > 0}}">
          <text>{{pendingReportCount > 99 ? '99+' : pendingReportCount}}</text>
        </view>
        <text class="menu-tag">管理员</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="area-card" wx:if="{{topAreas.length}}">
      <view class="section-head">
        <text class="section-title">足迹亮点</text>
        <view class="section-more" bindtap="onFootprintTap">
          <text class="section-subtitle">查看全部</text>
          <text class="section-arrow-sm">▸</text>
        </view>
      </view>
      <view class="area-list">
        <view class="area-item" wx:for="{{topAreas}}" wx:key="name">
          <view class="area-item-main">
            <text class="area-name">{{item.name}}</text>
            <text class="area-count">{{item.count}} 张</text>
          </view>
          <view class="area-progress">
            <view class="area-progress-inner" style="width: {{photoTotal ? (item.count / photoTotal * 100) : 0}}%;"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="section-head photo-section-head">
      <text class="section-title">我的拍摄</text>
      <text class="section-subtitle" wx:if="{{photoTotal > 0}}">共 {{photoTotal}} 张</text>
    </view>

    <view class="photo-grid" wx:if="{{photos.length}}">
      <view class="photo-cell" wx:for="{{photos}}" wx:key="id" bindtap="onPhotoTap" data-id="{{item.id}}">
        <image class="photo-thumb" src="{{item.thumbnailUrl || item.imageUrl}}" mode="aspectFill" />
        <view class="photo-meta">
          <text class="photo-loc">{{item.locationName}}</text>
          <view class="photo-bottom">
            <text class="photo-date">{{item.photoDateLabel}}</text>
            <view class="photo-stats">
              <view class="stat-item" wx:if="{{item.likeCount > 0}}">
                <text class="stat-icon like-icon">♥</text>
                <text class="stat-num">{{item.likeCount}}</text>
              </view>
              <view class="stat-item" wx:if="{{item.commentCount > 0}}">
                <text class="stat-icon comment-icon">💬</text>
                <text class="stat-num">{{item.commentCount}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="empty-tip" wx:if="{{!photos.length && !photoLoading}}">还没有拍摄记录，去地图上传第一张吧</view>
    <view class="loading-tip" wx:if="{{photoLoading}}">加载中...</view>
    <view class="loading-tip" wx:if="{{!photoHasMore && photos.length}}">没有更多了</view>

    <button class="logout-btn" bindtap="onLogout">退出登录</button>

    <!-- ===== 资料完善弹窗（底部滑出） ===== -->
    <view class="sheet-mask {{showSetupSheet ? 'visible' : ''}}" bindtap="onSheetMaskTap" catchtouchmove="noop"></view>
    <view class="sheet-panel {{showSetupSheet ? 'visible' : ''}}">
      <view class="sheet-handle"><view class="handle-bar"></view></view>

      <!-- 步骤指示（可点击回退） -->
      <view class="sheet-steps">
        <view class="s-step {{setupStep >= 1 ? 'done' : ''}} {{setupStep === 1 ? 'current' : ''}}" bindtap="onStepTap" data-step="1">
          <view class="s-dot">1</view>
          <text class="s-text">设置头像</text>
        </view>
        <view class="s-line {{setupStep >= 2 ? 'done' : ''}}"></view>
        <view class="s-step {{setupStep >= 2 ? 'done' : ''}} {{setupStep === 2 ? 'current' : ''}}" bindtap="onStepTap" data-step="2">
          <view class="s-dot">2</view>
          <text class="s-text">填写昵称</text>
        </view>
      </view>

      <!-- Step 1: 头像 -->
      <view class="sheet-body" wx:if="{{setupStep === 1}}">
        <view class="sheet-header">
          <text class="sheet-title">选择你的头像</text>
          <text class="sheet-desc">点击下方头像，从微信中选取</text>
        </view>
        <view class="sheet-center-block">
          <!-- 预览放在 button 外，避免 tmp 路径嵌套触发渲染层问题 -->
          <view class="sheet-avatar-picker">
            <view class="sheet-avatar-ring {{avatarPreview ? 'has-avatar' : ''}}">
              <image class="sheet-avatar-img" src="{{avatarPreview || '/images/icon-user.svg'}}" mode="aspectFill" />
              <view class="sheet-avatar-overlay" wx:if="{{!avatarPreview}}">
                <image class="overlay-icon" src="/images/icon-camera.svg" mode="aspectFit" />
                <text class="overlay-text">点击选择</text>
              </view>
            </view>
            <button class="sheet-avatar-hit" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
              <text class="sheet-avatar-hit-label">选择微信头像</text>
            </button>
          </view>
        </view>
        <view class="sheet-action">
          <button class="sheet-primary-btn {{avatarPreview && !avatarDownloading ? '' : 'disabled'}}" bindtap="onSetupNext">
            下一步
          </button>
        </view>
      </view>

      <!-- Step 2: 昵称 -->
      <view class="sheet-body" wx:if="{{setupStep === 2}}">
        <view class="sheet-header">
          <text class="sheet-title">设置你的昵称</text>
          <text class="sheet-desc">这将作为你在社区中的显示名称</text>
        </view>
        <view class="sheet-form-block">
          <view class="sheet-input-wrap">
            <input
              class="sheet-input"
              type="nickname"
              placeholder="输入昵称或选择微信昵称"
              maxlength="20"
              value="{{profileNickname}}"
              bindinput="onNicknameInput"
              bindblur="onNicknameBlur"
              focus="{{setupStep === 2}}"
            />
          </view>
          <text class="sheet-input-hint">2-20个字符，支持中英文和数字</text>
        </view>
        <view class="sheet-action">
          <view class="sheet-btn-row">
            <view class="sheet-back-btn" bindtap="onSetupBack">上一步</view>
            <button class="sheet-primary-btn flex-btn {{profileNickname ? '' : 'disabled'}}" bindtap="onSetupNext">
              完成设置
            </button>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
