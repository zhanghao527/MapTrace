/* ===== 页面容器 ===== */
.rank-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
}

/* ===== 顶部栏 ===== */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
}

/* ===== Tab 切换（复用社区页胶囊样式） ===== */
.sort-toggle {
  display: flex;
  align-items: center;
  background: rgba(0, 0, 0, 0.04);
  border-radius: 24rpx;
}
.sort-item {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #888;
  border-radius: 24rpx;
  white-space: nowrap;
  transition: all 0.2s ease;
}
.sort-item.active {
  color: #fff;
  background: #07c160;
  font-weight: 600;
}
.sort-item:active {
  opacity: 0.7;
}

/* ===== 统计摘要 ===== */
.stats-bar {
  padding: 0 24rpx 12rpx;
  text-align: center;
}
.stats-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

/* ===== 排行列表 ===== */
.rank-list {
  padding: 8rpx 24rpx;
}
.rank-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
}
.rank-item:active {
  opacity: 0.85;
}
.rank-index-col {
  width: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 36rpx;
}
.rank-num {
  font-size: 28rpx;
  color: #bbb;
  font-weight: 700;
}
.rank-num.top {
  color: #ff6b00;
  font-size: 32rpx;
}

/* ===== 排行卡片 ===== */
.rank-card {
  flex: 1;
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  min-width: 0;
}
.rank-thumb {
  width: 160rpx;
  height: 140rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}
.rank-thumb-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}
.rank-thumb-placeholder {
  width: 48rpx;
  height: 48rpx;
  opacity: 0.3;
}
.rank-info {
  flex: 1;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}
/* ===== 区县名 + 城市 ===== */
.rank-name-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}
.rank-district-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.rank-city-name {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  flex-shrink: 0;
}

/* ===== 数据行 ===== */
.rank-data-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 10rpx;
}
.rank-data-item {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.rank-data-num {
  font-size: 26rpx;
  color: #666;
  font-weight: 600;
}
.rank-data-label {
  font-size: 20rpx;
  color: #999;
}
.rank-data-item.highlight .rank-data-num {
  color: #07c160;
}
.rank-data-item.highlight .rank-data-label {
  color: #07c160;
  opacity: 0.7;
}

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 60rpx 0;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

/* ===== 加载提示 ===== */
.loading-tip {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #bbb;
}
