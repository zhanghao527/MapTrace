<view class="rank-page">

  <!-- 顶部：统计 + 排序 -->
  <view class="rank-top-bar">
    <text class="stats-text" wx:if="{{districtCount > 0}}">共 {{districtCount}} 个区县 · {{totalPhotos}} 张照片</text>
    <picker mode="selector" range="{{sortOptions}}" range-key="label" value="{{sortIndex}}" bindchange="onSortChange">
      <view class="sort-picker">
        <text class="sort-picker-label">{{sortOptions[sortIndex].label}}</text>
        <image class="sort-picker-arrow" src="/images/icon-arrow-right.svg" />
      </view>
    </picker>
  </view>

  <!-- 排行列表 -->
  <view class="rank-list" wx:if="{{!isEmpty && !loading}}">
    <view class="rank-item" wx:for="{{rankList}}" wx:key="district" bindtap="onDistrictTap" data-district="{{item.district}}" data-city="{{item.city}}">
      <view class="rank-index-col">
        <text class="rank-num {{item.rank <= 3 ? 'top' : ''}}">{{item.rank}}</text>
      </view>
      <view class="rank-card">
        <image class="rank-thumb" src="{{item.latestThumbUrl}}" mode="aspectFill" lazy-load wx:if="{{item.latestThumbUrl}}" />
        <view class="rank-thumb rank-thumb-empty" wx:else>
          <image class="rank-thumb-placeholder" src="/images/icon-photo.svg" />
        </view>
        <view class="rank-info">
          <view class="rank-name-row">
            <text class="rank-district-name">{{item.district}}</text>
            <text class="rank-city-name" wx:if="{{item.city}}">{{item.city}}</text>
          </view>
          <view class="rank-data-row">
            <!-- 根据排序维度显示对应数据 -->
            <view class="rank-data-item highlight">
              <text class="rank-data-num" wx:if="{{sortBy === 'photoCount'}}">{{item.photoCount}}</text>
              <text class="rank-data-num" wx:elif="{{sortBy === 'likeCount'}}">{{item.likeCount}}</text>
              <text class="rank-data-num" wx:elif="{{sortBy === 'commentCount'}}">{{item.commentCount}}</text>
              <text class="rank-data-num" wx:elif="{{sortBy === 'createTime'}}">{{item.latestCreateTime}}</text>
              <text class="rank-data-num" wx:elif="{{sortBy === 'photoDate'}}">{{item.latestPhotoDate}}</text>
              <text class="rank-data-label" wx:if="{{sortBy === 'photoCount'}}">张照片</text>
              <text class="rank-data-label" wx:elif="{{sortBy === 'likeCount'}}">次点赞</text>
              <text class="rank-data-label" wx:elif="{{sortBy === 'commentCount'}}">条评论</text>
              <text class="rank-data-label" wx:elif="{{sortBy === 'createTime'}}">最近上传</text>
              <text class="rank-data-label" wx:elif="{{sortBy === 'photoDate'}}">最近拍摄</text>
            </view>
            <!-- 非照片数排序时，补充显示照片数 -->
            <view class="rank-data-item" wx:if="{{sortBy !== 'photoCount'}}">
              <text class="rank-data-num">{{item.photoCount}}</text>
              <text class="rank-data-label">张</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{isEmpty && !loading}}">
    <text class="empty-text">还没有区县上传照片</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

</view>
