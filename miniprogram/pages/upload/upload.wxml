<!-- 上传页 -->
<view class="container">
  <!-- 选择图片 -->
  <view class="image-picker" bindtap="chooseImage">
    <image wx:if="{{imagePath}}" src="{{imagePath}}" mode="aspectFill" />
    <view wx:else class="placeholder">
      <text>+</text>
      <text class="tip">选择图片</text>
    </view>
  </view>

  <!-- 拍摄日期 -->
  <view class="form-item">
    <text class="label">拍摄日期</text>
    <picker mode="date" value="{{photoDate}}" bindchange="onDateChange">
      <view class="picker-value">{{photoDate || '请选择日期'}}</view>
    </picker>
  </view>

  <!-- 地点 -->
  <view class="form-item" bindtap="chooseLocation">
    <text class="label">拍摄地点</text>
    <view class="picker-value">{{locationName || '请选择地点'}}</view>
  </view>

  <!-- 描述 -->
  <view class="form-item">
    <text class="label">图片描述</text>
    <textarea
      class="desc-input"
      placeholder="说说这张照片的故事..."
      value="{{description}}"
      bindinput="onDescInput"
      maxlength="200"
    />
  </view>

  <!-- 提交 -->
  <button class="submit-btn" type="primary" bindtap="submit">上传</button>
</view>
