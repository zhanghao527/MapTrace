/* 上传页样式 */
.container {
  padding: 30rpx;
}

.image-picker {
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
}

.image-picker image {
  width: 100%;
  height: 100%;
}

.placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.placeholder text:first-child {
  font-size: 80rpx;
  line-height: 1;
}

.tip {
  font-size: 26rpx;
  margin-top: 10rpx;
}

.form-item {
  background: #fff;
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.picker-value {
  font-size: 30rpx;
  color: #333;
}

.desc-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 30rpx;
}

.submit-btn {
  margin-top: 40rpx;
  border-radius: 12rpx;
}
