<view class="container">
  <!-- 顶部轻提示 -->
  <view class="top-toast {{showToast ? 'show' : ''}}">
    <text>{{uploadToast}}</text>
  </view>

  <!-- 顶部居中：区县名卡片 -->
  <view class="top-district-card" wx:if="{{districtName}}">
    <text class="district-text">📍 {{districtName}}</text>
  </view>

  <!-- 右侧工具栏 -->
  <view class="right-toolbar">
    <view class="toolbar-btn" bindtap="onProfileTap">
      <text class="toolbar-icon">👤</text>
    </view>
  </view>

  <!-- 时光筛选卡片（筛选生效时显示） -->
  <view class="filter-card {{filterActive ? 'active' : ''}} {{showActionBar || showFilterPanel ? 'hidden' : ''}}" wx:if="{{filterActive}}" bindtap="onFilterTap" hover-class="filter-card-hover">
    <view class="filter-bar-indicator"></view>
    <view class="filter-content">
      <view class="filter-main-row">
        <text class="filter-icon">🕐</text>
        <text class="filter-title">{{panelTab === 'day' ? '回忆当天' : panelTab === 'range' ? '回忆区间' : '全部时间'}}</text>
      </view>
      <text class="filter-sub" wx:if="{{filterLabel !== '全部时间'}}">{{filterLabel}}</text>
    </view>
    <text class="filter-arrow">▸</text>
  </view>

  <!-- 地图 -->
  <map
    id="map" class="map"
    latitude="{{latitude}}" longitude="{{longitude}}"
    scale="{{scale}}" markers="{{markers}}"
    show-location
    bindtap="onMapTap"
    bindmarkertap="onMarkerTap"
    bindcallouttap="onMarkerTap"
    bindregionchange="onRegionChange"
  >
    <!-- 照片缩略图 customCallout -->
    <block wx:for="{{photoMarkers}}" wx:key="id">
      <cover-view slot="callout" marker-id="{{item.id}}">
        <cover-view class="photo-callout">
          <cover-view class="photo-card">
            <cover-image class="photo-thumb" src="{{item.thumbUrl}}" />
          </cover-view>
          <cover-view class="photo-arrow"></cover-view>
        </cover-view>
      </cover-view>
    </block>
  </map>

  <!-- 一键定位按钮 -->
  <view class="locate-btn {{hasLocation ? '' : 'disabled'}}" bindtap="onLocateTap">
    <view class="locate-arrow"></view>
  </view>

  <!-- 悬浮底部栏 -->
  <view class="floating-bar {{showActionBar || showFilterPanel ? 'hidden' : ''}}">
    <view class="bar-btn" bindtap="onChatTap">
      <view class="bar-icon-circle">
        <text class="bar-icon-text">💬</text>
      </view>
    </view>
    <view class="bar-btn bar-btn-main" bindtap="onFilterTap">
      <view class="bar-icon-circle main">
        <text class="bar-icon-text">🕐</text>
      </view>
    </view>
    <view class="bar-btn" bindtap="onCommunityTap">
      <view class="bar-icon-circle">
        <text class="bar-icon-text">🏠</text>
      </view>
    </view>
  </view>

  <!-- 时光穿梭面板 -->
  <view class="filter-mask {{showFilterPanel ? 'show' : ''}}" bindtap="onMaskTap"></view>
  <view class="filter-panel {{showFilterPanel ? 'show' : ''}}">
    <!-- 顶部标题 -->
    <view class="panel-header">
      <text class="panel-title">穿梭时光</text>
      <text class="panel-close" bindtap="onCloseFilter">✕</text>
    </view>

    <!-- Tab 切换 -->
    <view class="panel-tabs">
      <view class="panel-tab {{panelTab === 'all' ? 'active' : ''}}" bindtap="onTabAll">全部时间</view>
      <view class="panel-tab {{panelTab === 'day' ? 'active' : ''}}" bindtap="onTabDay">回忆当天</view>
      <view class="panel-tab {{panelTab === 'range' ? 'active' : ''}}" bindtap="onTabRange">回忆区间</view>
    </view>

    <!-- 回忆当天：滚轮 -->
    <view class="wheel-area" wx:if="{{panelTab === 'day'}}">
      <view class="indicator-line"></view>
      <view class="fade-left"></view>
      <view class="fade-right"></view>

      <view class="wheel-label">年份</view>
      <scroll-view class="wheel-scroll" scroll-x scroll-left="{{yearScrollLeft}}" scroll-with-animation enhanced show-scrollbar="{{false}}" bindscroll="onYearScroll">
        <view class="wheel-track">
          <view class="wheel-pad"></view>
          <view wx:for="{{years}}" wx:key="*this" class="wheel-item year-item {{item === selectedYear ? 'selected' : (item === selectedYear - 1 || item === selectedYear + 1) ? 'adjacent' : 'far'}}" bindtap="onYearItemTap" data-year="{{item}}">{{item}}</view>
          <view class="wheel-pad"></view>
        </view>
      </scroll-view>

      <view class="wheel-label">月份</view>
      <scroll-view class="wheel-scroll" scroll-x scroll-left="{{monthScrollLeft}}" scroll-with-animation enhanced show-scrollbar="{{false}}" bindscroll="onMonthScroll">
        <view class="wheel-track">
          <view class="wheel-pad"></view>
          <view wx:for="{{months}}" wx:key="*this" class="wheel-item month-item {{item === selectedMonth ? 'selected' : (item === selectedMonth - 1 || item === selectedMonth + 1) ? 'adjacent' : 'far'}}" bindtap="onMonthItemTap" data-month="{{item}}">{{item}}月</view>
          <view class="wheel-pad"></view>
        </view>
      </scroll-view>

      <view class="wheel-label">日期</view>
      <scroll-view class="wheel-scroll" scroll-x scroll-left="{{dayScrollLeft}}" scroll-with-animation enhanced show-scrollbar="{{false}}" bindscroll="onDayScroll">
        <view class="wheel-track">
          <view class="wheel-pad"></view>
          <view wx:for="{{days}}" wx:key="*this" class="wheel-item day-item {{item === selectedDay ? 'selected' : (item === selectedDay - 1 || item === selectedDay + 1) ? 'adjacent' : 'far'}}" bindtap="onDayItemTap" data-day="{{item}}">{{item}}日</view>
          <view class="wheel-pad"></view>
        </view>
      </scroll-view>
    </view>

    <!-- 回忆区间：起止日期 -->
    <view class="range-area" wx:if="{{panelTab === 'range'}}">
      <view class="range-row">
        <text class="range-label">开始日期</text>
        <picker mode="date" value="{{rangeStart}}" bindchange="onRangeStartChange">
          <view class="range-date-btn {{rangeStart ? 'has-value' : ''}}">{{rangeStart || '请选择'}}</view>
        </picker>
      </view>
      <view class="range-row">
        <text class="range-label">结束日期</text>
        <picker mode="date" value="{{rangeEnd}}" bindchange="onRangeEndChange">
          <view class="range-date-btn {{rangeEnd ? 'has-value' : ''}}">{{rangeEnd || '请选择'}}</view>
        </picker>
      </view>
    </view>

    <!-- 底部操作按钮 -->
    <view class="panel-actions">
      <view class="panel-reset" bindtap="onFilterReset">重置</view>
      <view class="panel-confirm" bindtap="onFilterConfirm">确认穿梭</view>
    </view>
  </view>

  <!-- 底部操作栏（选点上传） -->
  <view class="action-bar {{showActionBar ? 'show' : ''}}">
    <view class="action-bar-inner">
      <view class="action-location">
        <text class="location-text">{{tapLocationName}}</text>
      </view>
      <picker mode="date" value="{{uploadDate}}" bindchange="onUploadDateChange">
        <view class="action-date">
          <text class="date-text">{{uploadDateDisplay}}</text>
        </view>
      </picker>
      <view class="action-buttons">
        <view class="btn-cancel" bindtap="onCancelTap">取消</view>
        <view class="btn-upload {{uploading ? 'disabled' : ''}}" bindtap="onGoUpload">
          {{uploading ? '上传中' : '去上传'}}
        </view>
      </view>
    </view>
  </view>
</view>
