<view class="container">
  <!-- 顶部轻提示 -->
  <view class="top-toast {{showToast ? 'show' : ''}}">
    <text>{{uploadToast}}</text>
  </view>

  <!-- 加载指示条 -->
  <view class="loading-bar {{loadingPhotos ? 'show' : ''}}"></view>

  <!-- 顶部居中：区县名卡片 -->
  <view class="top-district-card" wx:if="{{districtName}}" bindtap="onDistrictTap">
    <view class="district-row">
      <image class="district-icon" src="/images/icon-location.svg" />
      <text class="district-text">{{districtName}}</text>
    </view>
    <!-- 筛选模式 -->
    <view class="district-stats-row" wx:if="{{filterActive && areaTotal > 0}}">
      <text class="district-stats-line">{{filterLabel}} · {{areaFilterUsers}} 人拍摄了 {{areaTotal}} 张</text>
    </view>
    <view class="district-stats-row column" wx:if="{{filterActive && areaTotal === 0}}">
      <text class="district-stats-line">{{filterLabel}}暂无照片记录</text>
      <text class="district-stats-line hint">快来上传记录一张，大家一起分享吧</text>
    </view>
    <!-- 无筛选模式 -->
    <view class="district-stats-row" wx:if="{{!filterActive && areaTotal > 0}}">
      <text class="district-stats-line">共 {{areaTotal}} 张照片</text>
      <text class="district-stats-line" wx:if="{{areaToday > 0}}">今日 {{areaTodayUsers}} 人拍摄 {{areaToday}} 张</text>
    </view>
  </view>

  <!-- 右侧工具栏（去掉了"+"按钮） -->
  <view class="right-toolbar">
    <view class="toolbar-btn" bindtap="onProfileTap">
      <image class="toolbar-icon-img" src="/images/icon-user.svg" />
    </view>
    <view class="toolbar-btn" bindtap="onRefreshTap">
      <image class="toolbar-icon-img" src="/images/icon-refresh.svg" />
    </view>
    <view class="toolbar-btn {{photosHidden ? 'toolbar-btn-off' : ''}}" bindtap="onTogglePhotos">
      <image class="toolbar-icon-img" src="/images/icon-camera.svg" />
      <view class="toolbar-slash" wx:if="{{photosHidden}}"></view>
    </view>

    <view class="toolbar-btn" bindtap="onUploadHintTap">
      <image class="toolbar-icon-img" src="/images/icon-plus.svg" />
    </view>
  </view>

  <!-- 上传悬浮条 -->
  <view class="upload-float {{showUploadBar ? 'show' : ''}}" catchtap="">
    <!-- 隐藏照片提示条（内嵌在上传面板顶部） -->
    <view class="hide-photos-inline" wx:if="{{showHidePhotosBar}}">
      <image class="hide-photos-inline-icon" src="/images/icon-camera.svg" />
      <text class="hide-photos-inline-text">其他照片遮挡上传位置？</text>
      <view class="hide-photos-inline-btn primary" bindtap="onHidePhotosConfirm">隐藏</view>
      <view class="hide-photos-inline-btn" bindtap="onHidePhotosCancel">不用了</view>
    </view>
    <!-- 第一行：位置 -->
    <view class="upload-float-row">
      <image class="upload-float-icon" src="/images/icon-location.svg" />
      <text class="upload-float-addr">{{tapLocationName}}</text>
      <view class="upload-float-close" bindtap="onCancelUpload">✕</view>
    </view>
    <!-- 第二行：拍摄日期 -->
    <view class="upload-float-row">
      <picker mode="date" value="{{uploadDate}}" start="1900-01-01" end="{{todayDate}}" bindchange="onUploadDateChange">
        <view class="upload-float-date">
          <image class="upload-float-icon-sm" src="/images/icon-calendar.svg" />
          <text>拍摄于</text>
          <text>{{uploadDateDisplay}}</text>
        </view>
      </picker>
    </view>
    <!-- 第三行：描述输入（多行自适应换行，最多200字） -->
    <view class="upload-float-row upload-float-row-desc">
      <view class="upload-float-desc-wrap">
        <textarea class="upload-float-desc" placeholder="添加描述（可选）" value="{{uploadDesc}}" bindinput="onDescInput"
          maxlength="200" auto-height />
        <text class="upload-float-desc-count">{{uploadDescLength}}/200</text>
      </view>
    </view>
    <!-- 可见性选择 -->
    <view class="upload-float-row visibility-row">
      <view class="visibility-options">
        <view class="visibility-opt {{uploadVisibility === 0 ? 'active' : ''}}" bindtap="onVisibilityTap" data-v="0">
          <text class="visibility-icon">🔒</text><text>仅自己可见</text>
        </view>
        <view class="visibility-opt {{uploadVisibility === 1 ? 'active' : ''}}" bindtap="onVisibilityTap" data-v="1">
          <text class="visibility-icon">👥</text><text>互关可见</text>
        </view>
        <view class="visibility-opt {{uploadVisibility === 2 ? 'active' : ''}}" bindtap="onVisibilityTap" data-v="2">
          <text class="visibility-icon">🌍</text><text>所有人可见</text>
        </view>
      </view>
    </view>
    <!-- 照片选择 + 上传按钮 -->
    <view class="upload-float-row second">
      <scroll-view class="upload-float-images" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="upload-float-img-list">
          <block wx:for="{{selectedImages}}" wx:key="*this">
            <view class="upload-float-img-item">
              <image class="upload-float-img" src="{{item}}" mode="aspectFill" />
              <view class="upload-float-img-remove" bindtap="onRemoveImage" data-idx="{{index}}">✕</view>
            </view>
          </block>
          <view class="upload-float-img-add" bindtap="onTakePhoto" wx:if="{{uploadDateDisplay === '今天' && selectedImages.length < 9}}">
            <image class="upload-float-add-icon" src="/images/icon-camera.svg" />
          </view>
          <view class="upload-float-img-add" bindtap="onChooseImages" wx:if="{{selectedImages.length < 9}}">
            <image class="upload-float-add-icon" src="/images/icon-plus.svg" />
          </view>
        </view>
      </scroll-view>
      <view class="upload-float-submit {{uploading || !selectedImages.length ? 'disabled' : ''}}" bindtap="onSubmitUpload">
        {{uploading ? uploadProgress + '%' : '上传'}}
      </view>
    </view>
    <!-- 上传进度 -->
    <view class="upload-float-progress" wx:if="{{uploading}}">
      <view class="upload-float-progress-inner" style="width: {{uploadProgress}}%"></view>
    </view>
  </view>

  <!-- 时光筛选卡片 -->
  <view class="filter-card {{filterActive ? 'active' : ''}} {{showUploadBar || showHidePhotosBar || showFilterPanel ? 'hidden' : ''}}" wx:if="{{filterActive}}" bindtap="onFilterTap" hover-class="filter-card-hover">
    <view class="filter-bar-indicator"></view>
    <view class="filter-content">
      <view class="filter-main-row">
        <image class="filter-icon-img" src="/images/icon-clock.svg" />
        <text class="filter-title">{{panelTab === 'day' ? '回忆当天' : panelTab === 'range' ? '回忆区间' : '全部时间'}}</text>
      </view>
      <text class="filter-sub" wx:if="{{filterLabel !== '全部时间'}}">{{filterLabel}}</text>
    </view>
    <text class="filter-arrow">▸</text>
  </view>

  <!-- 空状态引导 -->
  <view class="empty-state" wx:if="{{emptyState && !showUploadBar && !showHidePhotosBar && !showFilterPanel && !loadingPhotos && !filterActive}}">
    <text class="empty-text">这里还没有时光记忆</text>
    <text class="empty-hint">点击地图任意位置，上传第一张照片</text>
  </view>

  <!-- 地图中心大头针 -->
  <view class="center-pin">
    <image class="pin-icon" src="/images/icon-pin.svg" />
  </view>

  <!-- 地图 -->
  <map
    id="map" class="map"
    latitude="{{latitude}}" longitude="{{longitude}}"
    scale="{{scale}}" markers="{{markers}}"
    show-location
    enable-poi
    bindtap="onMapTap"
    bindmarkertap="onMarkerTap"
    bindcallouttap="onMarkerTap"
    bindregionchange="onRegionChange"
  >
    <block wx:for="{{photoMarkers}}" wx:key="id">
      <cover-view slot="callout" marker-id="{{item.id}}">
        <cover-view class="photo-callout">
          <cover-view class="photo-card">
            <cover-image class="photo-thumb" src="{{item.thumbUrl}}" />
            <cover-view class="photo-count" wx:if="{{item.count > 1}}">
              {{item.count > 99 ? '99+' : item.count}}
            </cover-view>
          </cover-view>
          <cover-view class="photo-arrow-wrap">
            <cover-view class="photo-arrow"></cover-view>
          </cover-view>
        </cover-view>
      </cover-view>
    </block>
    <!-- 临时上传标记 / 聚焦标记：始终在最上层 -->
    <cover-view slot="callout" marker-id="99999" wx:if="{{showUploadBar || showHidePhotosBar || showFocusMarker}}">
      <!-- 聚焦标记（从详情页跳转）：蓝色高亮边框 -->
      <cover-view class="photo-callout" wx:if="{{showFocusMarker && tempPreviewImage}}">
        <cover-view class="photo-card focus-card">
          <cover-image class="photo-thumb" src="{{tempPreviewImage}}" />
        </cover-view>
        <cover-view class="photo-arrow-wrap">
          <cover-view class="photo-arrow focus-arrow"></cover-view>
        </cover-view>
      </cover-view>
      <!-- 上传预览标记 -->
      <cover-view class="photo-callout" wx:elif="{{tempPreviewImage}}">
        <cover-view class="photo-card temp-card">
          <cover-image class="photo-thumb" src="{{tempPreviewImage}}" />
          <cover-view class="photo-count temp-count" wx:if="{{selectedImages.length > 1}}">{{selectedImages.length}}</cover-view>
        </cover-view>
        <cover-view class="photo-arrow temp-arrow"></cover-view>
      </cover-view>
      <cover-view class="upload-callout" wx:else>
        <cover-view class="upload-callout-text">上传位置</cover-view>
        <cover-view class="upload-callout-arrow"></cover-view>
      </cover-view>
    </cover-view>
  </map>

  <!-- 悬浮底部栏 -->
  <view class="floating-bar {{showUploadBar || showHidePhotosBar || showFilterPanel ? 'hidden' : ''}}">
    <view class="bar-btn" bindtap="onChatTap">
      <view class="bar-icon-circle">
        <image class="bar-icon-img" src="/images/icon-chat.svg" />
      </view>
      <view class="bar-badge" wx:if="{{unreadTotal > 0}}">
        <text>{{unreadTotal > 99 ? '99+' : unreadTotal}}</text>
      </view>
    </view>
    <view class="bar-btn bar-btn-main" bindtap="onFilterTap">
      <view class="bar-icon-circle main">
        <image class="bar-icon-img main" src="/images/icon-clock.svg" />
      </view>
    </view>
    <view class="bar-btn" bindtap="onCommunityTap">
      <view class="bar-icon-circle">
        <image class="bar-icon-img" src="/images/icon-community.svg" />
      </view>
    </view>
    <view class="bar-btn" bindtap="onRankTap">
      <view class="bar-icon-circle">
        <image class="bar-icon-img" src="/images/icon-rank.svg" />
      </view>
    </view>
  </view>

  <!-- 时光穿梭面板 -->
  <view class="filter-mask {{showFilterPanel ? 'show' : ''}}" bindtap="onMaskTap"></view>
  <view class="filter-panel {{showFilterPanel ? 'show' : ''}}">
    <view class="panel-header">
      <text class="panel-title">穿梭时光</text>
      <text class="panel-close" bindtap="onCloseFilter">✕</text>
    </view>
    <view class="panel-tabs">
      <view class="panel-tab {{panelTab === 'all' ? 'active' : ''}}" bindtap="onTabAll">全部时间</view>
      <view class="panel-tab {{panelTab === 'day' ? 'active' : ''}}" bindtap="onTabDay">回忆当天</view>
      <view class="panel-tab {{panelTab === 'range' ? 'active' : ''}}" bindtap="onTabRange">回忆区间</view>
    </view>
    <view class="wheel-area" wx:if="{{panelTab === 'day'}}">
      <view class="fade-left"></view>
      <view class="fade-right"></view>
      <view class="wheel-label">年份</view>
      <scroll-view class="wheel-scroll wheel-scroll-year" scroll-x scroll-left="{{yearScrollLeft}}" scroll-with-animation enhanced show-scrollbar="{{false}}" bindscroll="onYearScroll">
        <view class="wheel-track">
          <view class="wheel-pad"></view>
          <view wx:for="{{years}}" wx:key="*this" id="year-{{item}}" class="wheel-item year-item {{item === selectedYear ? 'selected' : (item === selectedYear - 1 || item === selectedYear + 1) ? 'adjacent' : 'far'}}" bindtap="onYearItemTap" data-year="{{item}}">{{item}}</view>
          <view class="wheel-pad"></view>
        </view>
      </scroll-view>
      <view class="wheel-label">月份</view>
      <scroll-view class="wheel-scroll wheel-scroll-month" scroll-x scroll-left="{{monthScrollLeft}}" scroll-with-animation enhanced show-scrollbar="{{false}}" bindscroll="onMonthScroll">
        <view class="wheel-track">
          <view class="wheel-pad"></view>
          <view wx:for="{{months}}" wx:key="*this" id="month-{{item}}" class="wheel-item month-item {{item === selectedMonth ? 'selected' : (item === selectedMonth - 1 || item === selectedMonth + 1) ? 'adjacent' : 'far'}}" bindtap="onMonthItemTap" data-month="{{item}}">{{item}}月</view>
          <view class="wheel-pad"></view>
        </view>
      </scroll-view>
      <view class="wheel-label">日期</view>
      <scroll-view class="wheel-scroll wheel-scroll-day" scroll-x scroll-left="{{dayScrollLeft}}" scroll-with-animation enhanced show-scrollbar="{{false}}" bindscroll="onDayScroll">
        <view class="wheel-track">
          <view class="wheel-pad"></view>
          <view wx:for="{{days}}" wx:key="*this" id="day-{{item}}" class="wheel-item day-item {{item === selectedDay ? 'selected' : (item === selectedDay - 1 || item === selectedDay + 1) ? 'adjacent' : 'far'}}" bindtap="onDayItemTap" data-day="{{item}}">{{item}}日</view>
          <view class="wheel-pad"></view>
        </view>
      </scroll-view>
    </view>
    <view class="range-area" wx:if="{{panelTab === 'range'}}">
      <view class="range-row">
        <text class="range-label">开始日期</text>
        <picker mode="date" value="{{rangeStart}}" bindchange="onRangeStartChange">
          <view class="range-date-btn {{rangeStart ? 'has-value' : ''}}">{{rangeStart || '请选择'}}</view>
        </picker>
      </view>
      <view class="range-row">
        <text class="range-label">结束日期</text>
        <picker mode="date" value="{{rangeEnd}}" bindchange="onRangeEndChange">
          <view class="range-date-btn {{rangeEnd ? 'has-value' : ''}}">{{rangeEnd || '请选择'}}</view>
        </picker>
      </view>
    </view>
    <view class="panel-actions">
      <view class="panel-reset" bindtap="onFilterReset">重置</view>
      <view class="panel-confirm" bindtap="onFilterConfirm">确认穿梭</view>
    </view>
  </view>
</view>
