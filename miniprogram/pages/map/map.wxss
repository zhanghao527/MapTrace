.container { width: 100%; height: 100vh; position: relative; }
.map { width: 100%; height: 100%; }

/* ===== 照片缩略图标记 ===== */
.photo-callout {
  display: flex; flex-direction: column; align-items: center;
}
.photo-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
}
.photo-thumb {
  width: 100rpx; height: 100rpx;
  border-radius: 12rpx;
}
.photo-arrow {
  width: 0; height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid #fff;
}

/* ===== 顶部轻提示 ===== */
.top-toast {
  position: fixed; top: -100rpx; left: 40rpx; right: 40rpx; z-index: 200;
  background: rgba(0,0,0,0.75); color: #fff; font-size: 26rpx;
  padding: 18rpx 30rpx; border-radius: 12rpx; text-align: center;
  transition: top 0.3s ease;
}
.top-toast.show { top: calc(env(safe-area-inset-top) + 20rpx); }

/* ===== 顶部区县卡片 ===== */
.top-district-card {
  position: fixed;
  top: 16rpx;
  left: 50%; transform: translateX(-50%);
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 28rpx;
  padding: 12rpx 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.08);
}
.district-text {
  font-size: 26rpx; color: #333; font-weight: 600;
}

/* ===== 右侧工具栏 ===== */
.right-toolbar {
  position: fixed;
  top: 16rpx;
  right: 24rpx; z-index: 100;
  display: flex; flex-direction: column; gap: 20rpx;
}
.toolbar-btn {
  width: 72rpx; height: 72rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
}
.toolbar-icon { font-size: 30rpx; }

/* ===== 时光筛选卡片（筛选生效时） ===== */
.filter-card {
  position: fixed; bottom: calc(env(safe-area-inset-bottom) + 220rpx);
  left: 50%; transform: translateX(-50%);
  z-index: 100;
  min-width: 360rpx; max-width: 520rpx;
  padding: 20rpx 28rpx 20rpx 0;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.1);
  display: flex; align-items: center;
  transition: all 0.25s ease;
  overflow: hidden;
}
.filter-card-hover {
  transform: translateX(-50%) scale(0.97);
}
.filter-bar-indicator {
  width: 6rpx; min-height: 48rpx; align-self: stretch;
  background: #07c160; border-radius: 3rpx;
  margin: 0 20rpx 0 0; flex-shrink: 0;
}
.filter-content {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 4rpx;
}
.filter-main-row {
  display: flex; align-items: center; gap: 10rpx;
}
.filter-icon { font-size: 28rpx; flex-shrink: 0; }
.filter-title {
  font-size: 28rpx; font-weight: 700; color: #07c160;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.filter-sub {
  font-size: 22rpx; color: #07c160; opacity: 0.75;
  padding-left: 38rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.filter-arrow {
  font-size: 28rpx; color: #07c160; flex-shrink: 0; margin-left: 12rpx;
}
.filter-card.hidden {
  opacity: 0; pointer-events: none;
  transform: translateX(-50%) translateY(20rpx);
}

/* ===== 一键定位按钮 ===== */
.locate-btn {
  position: fixed; right: 24rpx; bottom: calc(env(safe-area-inset-bottom) + 240rpx);
  z-index: 100;
  width: 72rpx; height: 72rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
}
.locate-btn.disabled { opacity: 0.4; }
.locate-arrow {
  width: 0; height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-bottom: 20rpx solid #4285f4;
  position: relative; top: -4rpx;
}
.locate-arrow::after {
  content: ''; position: absolute;
  top: 10rpx; left: -6rpx;
  width: 12rpx; height: 12rpx;
  background: #4285f4; border-radius: 50%;
}

/* ===== 悬浮底部栏 ===== */
.floating-bar {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  left: 50%; transform: translateX(-50%);
  z-index: 100;
  display: flex; align-items: center; gap: 40rpx;
  transition: all 0.25s ease;
}
.floating-bar.hidden {
  opacity: 0; pointer-events: none;
  transform: translateX(-50%) translateY(20rpx);
}
.bar-btn {
  display: flex; align-items: center; justify-content: center;
}
.bar-icon-circle {
  width: 96rpx; height: 96rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.1);
  transition: transform 0.2s ease;
}
.bar-icon-circle.main {
  width: 112rpx; height: 112rpx;
  background: rgba(255,255,255,0.95);
}
.bar-icon-circle:active {
  transform: scale(0.92);
}
.bar-icon-text {
  font-size: 36rpx;
}
.bar-btn-main .bar-icon-text {
  font-size: 42rpx;
}

/* ===== 时光穿梭面板 ===== */
.filter-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0); z-index: 150;
  pointer-events: none;
  transition: background 0.3s ease;
}
.filter-mask.show {
  background: rgba(0,0,0,0.3);
  pointer-events: auto;
}

.filter-panel {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 160;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 12rpx) 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.filter-panel.show {
  transform: translateY(0);
}

.panel-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx 12rpx;
}
.panel-title {
  font-size: 30rpx; font-weight: 700; color: #1a1a1a;
}
.panel-close {
  font-size: 32rpx; color: #999; padding: 8rpx;
  width: 50rpx; height: 50rpx;
  display: flex; align-items: center; justify-content: center;
}

.panel-tabs {
  display: flex; margin: 0 32rpx 12rpx; gap: 0;
  background: #f0f0f0; border-radius: 20rpx; padding: 4rpx;
}
.panel-tab {
  flex: 1; text-align: center;
  height: 52rpx; line-height: 52rpx;
  font-size: 24rpx; color: #666;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}
.panel-tab.active {
  background: #fff; color: #1a1a1a; font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.range-area { padding: 8rpx 32rpx 12rpx; }
.range-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.range-row:last-child { border-bottom: none; }
.range-label { font-size: 26rpx; color: #666; }
.range-date-btn {
  font-size: 26rpx; color: #999;
  background: #f5f5f5; padding: 10rpx 24rpx; border-radius: 20rpx;
}
.range-date-btn.has-value { color: #07c160; background: #f0f9f0; }

/* ===== 滚轮区域 ===== */
.wheel-area {
  position: relative;
  padding: 8rpx 0 4rpx;
}
.indicator-line {
  position: absolute;
  left: 50%; top: 0; bottom: 0;
  width: 3rpx; background: #07c160;
  transform: translateX(-50%);
  z-index: 10; border-radius: 2rpx; opacity: 0.8;
}
.indicator-line::before {
  content: '';
  position: absolute; top: -5rpx; left: 50%;
  transform: translateX(-50%);
  width: 10rpx; height: 10rpx;
  background: #07c160; border-radius: 50%;
}
.indicator-line::after {
  content: '';
  position: absolute; bottom: -5rpx; left: 50%;
  transform: translateX(-50%);
  width: 10rpx; height: 10rpx;
  background: #07c160; border-radius: 50%;
}
.fade-left {
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 80rpx; z-index: 5;
  background: linear-gradient(to right, rgba(255,255,255,0.92), rgba(255,255,255,0));
  pointer-events: none;
}
.fade-right {
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 80rpx; z-index: 5;
  background: linear-gradient(to left, rgba(255,255,255,0.92), rgba(255,255,255,0));
  pointer-events: none;
}
.wheel-label {
  font-size: 20rpx; color: #999; padding: 4rpx 32rpx 2rpx; font-weight: 500;
}
.wheel-scroll { width: 100%; height: 72rpx; white-space: nowrap; }
.wheel-track { display: inline-flex; align-items: center; height: 72rpx; }
.wheel-pad { width: calc(50vw - 60rpx); flex-shrink: 0; }
.wheel-item {
  width: 120rpx; flex-shrink: 0; text-align: center;
  transition: all 0.25s ease;
  display: flex; align-items: center; justify-content: center;
  height: 72rpx;
}
.year-item.far { font-size: 26rpx; color: #bbb; opacity: 0.5; }
.year-item.adjacent { font-size: 30rpx; color: #666; opacity: 0.8; }
.year-item.selected { font-size: 38rpx; color: #07c160; font-weight: 700; opacity: 1; }
.month-item.far { font-size: 22rpx; color: #bbb; opacity: 0.5; }
.month-item.adjacent { font-size: 26rpx; color: #666; opacity: 0.8; }
.month-item.selected { font-size: 34rpx; color: #07c160; font-weight: 700; opacity: 1; }
.day-item.far { font-size: 20rpx; color: #bbb; opacity: 0.5; }
.day-item.adjacent { font-size: 24rpx; color: #666; opacity: 0.8; }
.day-item.selected { font-size: 30rpx; color: #07c160; font-weight: 700; opacity: 1; }

/* ===== 底部操作按钮 ===== */
.panel-actions {
  display: flex; gap: 16rpx; padding: 12rpx 32rpx 0;
}
.panel-reset {
  flex: 1; text-align: center;
  height: 72rpx; line-height: 72rpx;
  font-size: 26rpx; color: #666;
  background: #fff; border: 2rpx solid #e0e0e0; border-radius: 36rpx;
}
.panel-confirm {
  flex: 2; text-align: center;
  height: 72rpx; line-height: 72rpx;
  font-size: 28rpx; color: #fff; font-weight: 600;
  background: #07c160; border-radius: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}

/* ===== 底部操作栏（上传选点） ===== */
.action-bar {
  position: fixed; bottom: -300rpx; left: 0; right: 0; z-index: 90;
  transition: bottom 0.3s ease;
}
.action-bar.show { bottom: 0; }
.action-bar-inner {
  margin: 0 20rpx; margin-bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 16rpx; padding: 24rpx 28rpx;
  box-shadow: 0 -4rpx 30rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: space-between;
}
.action-location { flex: 1; min-width: 0; }
.location-text {
  font-size: 24rpx; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; display: block;
}
.action-date {
  padding: 8rpx 20rpx; background: #f5f5f5;
  border-radius: 20rpx; flex-shrink: 0; margin: 0 16rpx;
}
.date-text { font-size: 24rpx; color: #333; }
.action-buttons { display: flex; align-items: center; flex-shrink: 0; gap: 16rpx; }
.btn-cancel { font-size: 26rpx; color: #999; padding: 10rpx 16rpx; }
.btn-upload {
  background: #07c160; color: #fff; font-size: 26rpx; font-weight: 600;
  padding: 16rpx 36rpx; border-radius: 30rpx;
}
.btn-upload.disabled { opacity: 0.5; }
