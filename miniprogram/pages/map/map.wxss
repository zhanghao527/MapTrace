page { background-color: transparent; }
.container { width: 100%; height: 100vh; position: relative; }
.map { width: 100%; height: 100%; }

/* ===== 地图中心大头针 ===== */
.center-pin {
  position: absolute;
  left: 50%; top: 50%;
  z-index: 90;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.pin-icon {
  width: 24px; height: 36px;
  transform: translate(-50%, -100%);
}

/* ===== 加载指示条 ===== */
.loading-bar {
  position: fixed; top: 0; left: 0; right: 0; height: 4rpx;
  z-index: 210; opacity: 0; transition: opacity 0.2s;
}
.loading-bar.show {
  opacity: 1;
  background: linear-gradient(90deg, transparent, #07c160, transparent);
  animation: loadingSlide 1.2s ease-in-out infinite;
}
@keyframes loadingSlide {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* ===== 照片缩略图标记 ===== */
.photo-callout {
  display: flex; flex-direction: column; align-items: center;
}
.photo-card {
  background: rgba(255, 255, 255, 0.85);
  border: 2rpx solid #fff;
  border-radius: 16rpx;
  box-shadow: 8rpx 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}
.photo-thumb {
  width: 108rpx; height: 100rpx;
  display: block;
}
/* 底部信息栏 */
.photo-bar {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 6rpx;
  height: 24rpx;
  padding: 2rpx 4rpx;
  background: rgba(255, 255, 255, 0.85);
}
.photo-bar-comment {
  min-width: 0;
  height: 20rpx; line-height: 20rpx;
  background: rgba(0, 0, 0, 0.08); color: #666;
  font-size: 10rpx; font-weight: 400; text-align: center;
  border-radius: 999rpx; padding: 0 4rpx;
  flex-shrink: 1;
  white-space: nowrap;
}
.photo-bar-like {
  min-width: 0;
  height: 20rpx; line-height: 20rpx;
  background: rgba(255, 77, 79, 0.15); color: #e64340;
  font-size: 10rpx; font-weight: 400; text-align: center;
  border-radius: 999rpx; padding: 0 4rpx;
  flex-shrink: 1;
  white-space: nowrap;
}
.photo-bar-count {
  min-width: 0;
  height: 20rpx; line-height: 20rpx;
  background: #165DFF; color: #fff;
  font-size: 10rpx; font-weight: 500; text-align: center;
  border-radius: 999rpx; padding: 0 4rpx;
  flex-shrink: 1;
  white-space: nowrap;
}
.photo-arrow {
  width: 18rpx;
  height: 18rpx;
  background: rgba(255, 255, 255, 0.85);
  transform: translateY(-9rpx) rotate(45deg);
  border-radius: 0;
  pointer-events: none;
}
.photo-arrow-wrap {
  width: 28rpx;
  height: 14rpx;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  pointer-events: none;
}


/* 待上传照片标记：淡绿色卡片 */
.temp-card {
  background: #e8f8ee;
  border: 3rpx solid #07c160;
  border-radius: 20rpx;
}

/* 聚焦标记（从详情页跳转）：蓝色高亮卡片 */
.focus-card {
  background: #e6f0ff;
  border: 3rpx solid #165DFF;
  border-radius: 20rpx;
}
.focus-arrow {
  background: #e6f0ff;
  border-right: 3rpx solid #165DFF;
  border-bottom: 3rpx solid #165DFF;
}
.photo-count {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  font-size: 10rpx;
  font-weight: 600;
  line-height: 1;
  color: #fff;
  background: #165DFF;
  pointer-events: none;
}
.temp-count {
  background: #07c160;
}
.temp-arrow {
  width: 16rpx; height: 16rpx;
  background: #07c160;
  border-radius: 50%;
  border-top: none;
  border-left: none;
  border-right: none;
  margin-top: 4rpx;
}

/* 上传位置标记 */
.upload-callout {
  display: flex; flex-direction: column; align-items: center;
}
.upload-callout-card {
  display: flex; align-items: center; gap: 8rpx;
  background: rgba(255, 255, 255, 0.95);
  padding: 14rpx 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}
.upload-callout-icon {
  width: 36rpx; height: 36rpx; line-height: 36rpx;
  text-align: center;
  background: #07c160; color: #fff;
  border-radius: 50%;
  font-size: 24rpx; font-weight: 600;
}
.upload-callout-label {
  font-size: 24rpx; color: #333; font-weight: 500;
}

/* ===== 顶部轻提示 ===== */
/* 收起用 translateY 上移，配合 opacity/visibility 彻底隐藏，避免留“尾巴” */
.top-toast {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 40rpx; right: 40rpx; z-index: 200;
  background: rgba(0,0,0,0.75); color: #fff; font-size: 26rpx;
  padding: 18rpx 30rpx; border-radius: 12rpx; text-align: center;
  transform: translateY(-120%);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: transform 0.25s ease-out, opacity 0.2s ease-out, visibility 0.01s;
}
.top-toast.show {
  transform: translateY(0);
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

/* ===== 顶部区县卡片 ===== */
.top-district-card {
  position: fixed;
  top: 16rpx;
  left: 50%; transform: translateX(-50%);
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 20rpx;
  padding: 14rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.08);
  display: flex; flex-direction: column; align-items: center;
  gap: 4rpx;
}
.top-district-card:active { opacity: 0.7; }
.district-row {
  display: flex; align-items: center;
}
.district-icon {
  width: 28rpx; height: 28rpx; margin-right: 8rpx;
}
.district-text {
  font-size: 26rpx; color: #333; font-weight: 600;
}
.district-stats-row {
  display: flex; align-items: center; gap: 12rpx;
}
.district-stats-row.column {
  flex-direction: column; align-items: center; gap: 2rpx;
}
.district-stats-line {
  font-size: 20rpx; color: #999;
}
.district-stats-line.hint {
  font-size: 18rpx; color: #bbb;
}

/* ===== 右侧工具栏 ===== */
.right-toolbar {
  position: fixed;
  top: 16rpx;
  right: 24rpx; z-index: 100;
  display: flex; flex-direction: column; gap: 20rpx;
}
.toolbar-btn {
  width: 72rpx; height: 72rpx;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 50%;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
  display: flex; align-items: center; justify-content: center;
  position: relative; overflow: hidden;
}
.toolbar-btn:active { opacity: 0.6; }
.toolbar-btn-off { opacity: 0.5; }
.toolbar-slash {
  position: absolute;
  top: 50%; left: 50%;
  width: 56rpx; height: 4rpx;
  background: #e74c3c;
  transform: translate(-50%, -50%) rotate(-45deg);
  border-radius: 2rpx;
}
.toolbar-icon-img { width: 36rpx; height: 36rpx; }

/* ===== 空状态引导 ===== */
.empty-state {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, 20rpx);
  z-index: 90;
  display: flex; flex-direction: column; align-items: center;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-radius: 20rpx; padding: 28rpx 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}
.empty-text {
  font-size: 28rpx; color: #666; font-weight: 600;
}
.empty-hint {
  font-size: 22rpx; color: #999; margin-top: 8rpx;
}

/* ===== 隐藏照片提示条（内嵌上传面板） ===== */
.hide-photos-inline {
  display: flex; align-items: center;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  margin: -18rpx -22rpx 12rpx;
  background: #fff8e6;
  border-radius: 20rpx 20rpx 0 0;
  border-bottom: 1rpx solid #f0e6c8;
}
.hide-photos-inline-icon {
  width: 32rpx; height: 32rpx; flex-shrink: 0; opacity: 0.6;
}
.hide-photos-inline-text {
  flex: 1; font-size: var(--font-sm); color: #8a6d00;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.hide-photos-inline-btn {
  flex-shrink: 0;
  font-size: var(--font-sm); color: #666;
  padding: 8rpx 18rpx;
  background: rgba(0,0,0,0.05); border-radius: var(--radius-lg);
}
.hide-photos-inline-btn.primary {
  color: #fff; background: #07c160;
}
.hide-photos-inline-btn:active { opacity: 0.7; }

/* ===== 上传悬浮条 ===== */
.upload-float {
  position: fixed;
  bottom: -800rpx;
  left: 24rpx; right: 24rpx;
  z-index: 170;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.12);
  padding: 18rpx 22rpx;
  transition: bottom 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.upload-float.show {
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
}

.upload-float-row {
  display: flex; align-items: center; gap: 12rpx;
  min-height: 48rpx;
  margin-bottom: 12rpx;
}
.upload-float-row:last-of-type { margin-bottom: 0; }
.upload-float-row.second {
  margin-top: 4rpx;
  margin-bottom: 0;
}
.upload-float-row-desc {
  align-items: flex-start;
}
.upload-float-desc-wrap {
  flex: 1; min-width: 0; display: flex; flex-direction: column;
}
.upload-float-icon {
  width: 28rpx; height: 28rpx; flex-shrink: 0; opacity: 0.6;
}
.upload-float-addr {
  flex: 1; font-size: 24rpx; color: #333;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.upload-float-date {
  flex-shrink: 0;
  display: flex; align-items: center; gap: 6rpx;
  font-size: 22rpx; color: #07c160;
  background: #f0f9f0; padding: 10rpx 16rpx; border-radius: 16rpx;
  min-height: 40rpx; line-height: 1.4;
}
.upload-float-icon-sm {
  width: 24rpx; height: 24rpx;
}
.upload-float-close {
  flex-shrink: 0;
  min-width: 56rpx; min-height: 56rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; color: #999;
}
.upload-float-close:active { opacity: 0.5; }

/* 照片横向滚动区 */
.upload-float-images {
  flex: 1; min-width: 0; height: 96rpx;
}

/* 描述输入（多行自适应换行） */
.upload-float-desc {
  flex: 1; min-height: 58rpx; max-height: 160rpx; width: 100%;
  font-size: 24rpx; color: #333;
  background: #f5f5f5; border-radius: 28rpx;
  padding: 14rpx 24rpx; line-height: 1.5;
  box-sizing: border-box;
}
.upload-float-desc-count {
  font-size: 20rpx; color: #999;
  text-align: right; margin-top: 6rpx; padding-right: 8rpx;
}
.upload-float-img-list {
  display: inline-flex; gap: 16rpx; height: 96rpx; align-items: center;
}
.upload-float-img-item {
  width: 88rpx; height: 88rpx;
  border-radius: 12rpx; overflow: hidden;
  position: relative; flex-shrink: 0;
}
.upload-float-img {
  width: 100%; height: 100%;
}
.upload-float-img-remove {
  position: absolute; top: 2rpx; right: 2rpx;
  width: 28rpx; height: 28rpx; line-height: 28rpx;
  text-align: center; font-size: 18rpx;
  background: rgba(0,0,0,0.5); color: #fff;
  border-radius: 50%;
}
.upload-float-img-add {
  width: 88rpx; height: 88rpx; flex-shrink: 0;
  min-width: 88rpx; min-height: 88rpx;
  border: 2rpx dashed #ccc; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center;
}
.upload-float-close-icon {
  width: 24rpx; height: 24rpx; opacity: 0.4;
}
.upload-float-remove-icon {
  width: 16rpx; height: 16rpx;
}
.upload-float-add-icon { width: 36rpx; height: 36rpx; opacity: 0.4; }

/* 可见性选择 */
.visibility-row { margin-bottom: 8rpx; }
.visibility-options {
  display: flex; gap: 12rpx; width: 100%;
}
.visibility-opt {
  flex: 1; display: flex; align-items: center; justify-content: center;
  gap: 6rpx; height: 60rpx;
  font-size: 22rpx; color: #999;
  background: #f5f5f5; border-radius: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}
.visibility-opt.active {
  color: #07c160; background: #f0f9f0;
  border-color: #07c160; font-weight: 600;
}
.visibility-opt:active { opacity: 0.7; }
/* 可见性选择（图标已移除，纯文字） */

/* 上传按钮 */
.upload-float-submit {
  flex-shrink: 0;
  min-height: 66rpx; height: 66rpx; line-height: 66rpx;
  padding: 0 28rpx;
  font-size: 26rpx; color: #fff; font-weight: 600;
  background: #07c160; border-radius: 32rpx;
  text-align: center;
}
.upload-float-submit.disabled { opacity: 0.4; }
.upload-float-submit:active { opacity: 0.8; }

/* 上传进度条 */
.upload-float-progress {
  margin-top: 12rpx; height: 4rpx;
  background: #f0f0f0; border-radius: 2rpx;
  overflow: hidden;
}
.upload-float-progress-inner {
  height: 100%; background: #07c160;
  border-radius: 2rpx; transition: width 0.3s ease;
}

/* ===== 时光筛选卡片（筛选生效时） ===== */
.filter-card {
  position: fixed; bottom: calc(env(safe-area-inset-bottom) + 220rpx);
  left: 50%; transform: translateX(-50%);
  z-index: 100;
  min-width: 360rpx; max-width: 520rpx;
  padding: 20rpx 28rpx 20rpx 0;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.1);
  display: flex; align-items: center;
  transition: all 0.25s ease;
  overflow: hidden;
}
.filter-card-hover {
  transform: translateX(-50%) scale(0.97);
}
.filter-bar-indicator {
  width: 6rpx; min-height: 48rpx; align-self: stretch;
  background: #07c160; border-radius: 3rpx;
  margin: 0 20rpx 0 0; flex-shrink: 0;
}
.filter-content {
  flex: 1; min-width: 0;
  display: flex; flex-direction: column; gap: 4rpx;
}
.filter-main-row {
  display: flex; align-items: center; gap: 10rpx;
}
.filter-icon-img { width: 32rpx; height: 32rpx; flex-shrink: 0; }
.filter-title {
  font-size: 28rpx; font-weight: 700; color: #07c160;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.filter-sub {
  font-size: 22rpx; color: #07c160; opacity: 0.75;
  padding-left: 38rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.filter-arrow {
  width: 28rpx; height: 28rpx; flex-shrink: 0; margin-left: 12rpx; opacity: 0.6;
}
.filter-card.hidden {
  opacity: 0; pointer-events: none;
  transform: translateX(-50%) translateY(20rpx);
}

/* ===== 悬浮底部栏 ===== */
.floating-bar {
  position: fixed;
  bottom: calc(env(safe-area-inset-bottom) + 40rpx);
  left: 50%; transform: translateX(-50%);
  z-index: 100;
  display: flex; align-items: center; gap: 28rpx;
  transition: all 0.25s ease;
}
.floating-bar.hidden {
  opacity: 0; pointer-events: none;
  transform: translateX(-50%) translateY(20rpx);
}
.bar-btn {
  display: flex; align-items: center; justify-content: center;
  position: relative;
}
.bar-badge {
  position: absolute; top: -4rpx; right: -4rpx;
  min-width: 32rpx; height: 32rpx; line-height: 32rpx;
  background: #e74c3c; color: #fff;
  font-size: 18rpx; font-weight: 600;
  text-align: center; border-radius: 999rpx;
  padding: 0 8rpx; box-sizing: border-box;
  z-index: 10;
}
.bar-icon-circle {
  width: 96rpx; height: 96rpx;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.1);
  transition: transform 0.2s ease;
}
.bar-icon-circle.main {
  width: 112rpx; height: 112rpx;
  background: rgba(255,255,255,0.95);
}
.bar-icon-circle:active {
  transform: scale(0.92);
}
.bar-icon-img {
  width: 44rpx; height: 44rpx;
}
.bar-icon-img.main {
  width: 52rpx; height: 52rpx;
}

/* ===== 时光穿梭面板 ===== */
.filter-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0); z-index: 150;
  pointer-events: none;
  transition: background 0.3s ease;
}
.filter-mask.show {
  background: rgba(0,0,0,0.3);
  pointer-events: auto;
}

.filter-panel {
  position: fixed; bottom: 0; left: 0; right: 0; z-index: 160;
  background: rgba(255,255,255,0.92);
  backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 12rpx) 0;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.filter-panel.show {
  transform: translateY(0);
}

.panel-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx 12rpx;
}
.panel-title {
  font-size: 30rpx; font-weight: 700; color: #1a1a1a;
}
.panel-close {
  padding: 8rpx;
  width: 50rpx; height: 50rpx;
  display: flex; align-items: center; justify-content: center;
}
.panel-close-icon {
  width: 28rpx; height: 28rpx; opacity: 0.4;
}

.panel-tabs {
  display: flex; margin: 0 32rpx 12rpx; gap: 0;
  background: #f0f0f0; border-radius: 20rpx; padding: 4rpx;
}
.panel-tab {
  flex: 1; text-align: center;
  height: 52rpx; line-height: 52rpx;
  font-size: 24rpx; color: #666;
  border-radius: 16rpx;
  transition: all 0.2s ease;
}
.panel-tab.active {
  background: #fff; color: #1a1a1a; font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.range-area { padding: 8rpx 32rpx 12rpx; }
.range-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0;
}
.range-row:last-child { border-bottom: none; }
.range-label { font-size: 26rpx; color: #666; }
.range-date-btn {
  font-size: 26rpx; color: #999;
  background: #f5f5f5; padding: 10rpx 24rpx; border-radius: 20rpx;
}
.range-date-btn.has-value { color: #07c160; background: #f0f9f0; }

/* ===== 滚轮区域 ===== */
.wheel-area {
  position: relative;
  padding: 8rpx 0 4rpx;
}
.indicator-line {
  position: absolute;
  left: 50%; top: 0; bottom: 0;
  width: 3rpx; background: #07c160;
  transform: translateX(-50%);
  z-index: 10; border-radius: 2rpx; opacity: 0.8;
}
.indicator-line::before {
  content: '';
  position: absolute; top: -5rpx; left: 50%;
  transform: translateX(-50%);
  width: 10rpx; height: 10rpx;
  background: #07c160; border-radius: 50%;
}
.indicator-line::after {
  content: '';
  position: absolute; bottom: -5rpx; left: 50%;
  transform: translateX(-50%);
  width: 10rpx; height: 10rpx;
  background: #07c160; border-radius: 50%;
}
.fade-left {
  position: absolute; left: 0; top: 0; bottom: 0;
  width: 80rpx; z-index: 5;
  background: linear-gradient(to right, rgba(255,255,255,0.92), rgba(255,255,255,0));
  pointer-events: none;
}
.fade-right {
  position: absolute; right: 0; top: 0; bottom: 0;
  width: 80rpx; z-index: 5;
  background: linear-gradient(to left, rgba(255,255,255,0.92), rgba(255,255,255,0));
  pointer-events: none;
}
.wheel-label {
  font-size: 20rpx; color: #999; padding: 4rpx 32rpx 2rpx; font-weight: 500;
}
.wheel-scroll { width: 100%; height: 72rpx; white-space: nowrap; }
.wheel-track { display: inline-flex; align-items: center; height: 72rpx; }
.wheel-pad { width: calc(50vw - 60rpx); flex-shrink: 0; }
.wheel-item {
  width: 120rpx; flex-shrink: 0; text-align: center;
  transition: all 0.25s ease;
  display: flex; align-items: center; justify-content: center;
  height: 72rpx;
}
.year-item.far { font-size: 26rpx; color: #bbb; opacity: 0.5; }
.year-item.adjacent { font-size: 30rpx; color: #666; opacity: 0.8; }
.year-item.selected { font-size: 38rpx; color: #07c160; font-weight: 700; opacity: 1; }
.month-item.far { font-size: 22rpx; color: #bbb; opacity: 0.5; }
.month-item.adjacent { font-size: 26rpx; color: #666; opacity: 0.8; }
.month-item.selected { font-size: 34rpx; color: #07c160; font-weight: 700; opacity: 1; }
.day-item.far { font-size: 20rpx; color: #bbb; opacity: 0.5; }
.day-item.adjacent { font-size: 24rpx; color: #666; opacity: 0.8; }
.day-item.selected { font-size: 30rpx; color: #07c160; font-weight: 700; opacity: 1; }

/* ===== 底部操作按钮 ===== */
.panel-actions {
  display: flex; gap: 16rpx; padding: 12rpx 32rpx 0;
}
.panel-reset {
  flex: 1; text-align: center;
  height: 72rpx; line-height: 72rpx;
  font-size: 26rpx; color: #666;
  background: #fff; border: 2rpx solid #e0e0e0; border-radius: 36rpx;
}
.panel-confirm {
  flex: 2; text-align: center;
  height: 72rpx; line-height: 72rpx;
  font-size: 28rpx; color: #fff; font-weight: 600;
  background: #07c160; border-radius: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(7,193,96,0.3);
}
