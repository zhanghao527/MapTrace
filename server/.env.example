# 地图时迹 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
# MySQL 数据库密码
export DB_PASSWORD=your_mysql_password

# ==================== JWT 配置 ====================
# JWT 签名密钥（用于生成用户登录 Token）
# 生成方法：openssl rand -base64 32
export JWT_SECRET=your_generated_jwt_secret_here

# ==================== Redis 配置 ====================
# Redis 服务器地址
export REDIS_HOST=localhost
# Redis 端口
export REDIS_PORT=6379
# Redis 密码（如果没有设置密码，留空）
export REDIS_PASSWORD=

# ==================== 腾讯云 COS 配置 ====================
# 腾讯云 COS SecretId（用于上传图片）
export COS_SECRET_ID=your_tencent_cos_secret_id
# 腾讯云 COS SecretKey
export COS_SECRET_KEY=your_tencent_cos_secret_key
# COS 地域
export COS_REGION=ap-shanghai
# COS 存储桶名称
export COS_BUCKET=your-bucket-name

# ==================== 微信小程序配置 ====================
# 微信小程序 AppID
export WX_APP_ID=your_wechat_app_id
# 微信小程序 AppSecret
export WX_APP_SECRET=your_wechat_app_secret

# ==================== 腾讯地图配置 ====================
# 腾讯地图 API Key
export TENCENT_MAP_KEY=your_tencent_map_key

# ==================== 管理员配置 ====================
# 管理员用户 ID 列表（逗号分隔）
export ADMIN_USER_IDS=

# ==================== MyBatis 配置 ====================
# SQL 日志实现（开发环境用 stdout，生产环境用 nologging）
# 开发环境：org.apache.ibatis.logging.stdout.StdOutImpl
# 生产环境：org.apache.ibatis.logging.nologging.NoLoggingImpl
export MYBATIS_LOG_IMPL=org.apache.ibatis.logging.nologging.NoLoggingImpl
