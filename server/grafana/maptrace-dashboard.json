{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "📊 概览",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "照片上传总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [{ "expr": "sum(photo_upload_total) or vector(0)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "title": "评论总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "sum(comment_total) or vector(0)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "点赞总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "sum(like_total{action=\"like\"}) or vector(0)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "orange", "value": null }] } } }
    },
    {
      "title": "私信总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "sum(message_send_total) or vector(0)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "title": "举报总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "sum(report_submit_total) or vector(0)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "title": "业务异常总数",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "sum(business_error_total) or vector(0)", "legendFormat": "" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "title": "📈 趋势分析",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "照片上传速率（每分钟）",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "sum(rate(photo_upload_total[5m])) * 60", "legendFormat": "总上传" },
        { "expr": "sum(rate(photo_upload_total[5m])) by (district) * 60", "legendFormat": "{{district}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "社交互动速率（每分钟）",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "sum(rate(comment_total[5m])) * 60", "legendFormat": "评论" },
        { "expr": "sum(rate(like_total{action=\"like\"}[5m])) * 60", "legendFormat": "点赞" },
        { "expr": "sum(rate(message_send_total[5m])) * 60", "legendFormat": "私信" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "举报趋势（每分钟）",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "sum(rate(report_submit_total[5m])) by (target_type) * 60", "legendFormat": "{{target_type}}" },
        { "expr": "sum(rate(report_handle_total[5m])) by (result) * 60", "legendFormat": "处理-{{result}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "业务异常趋势（每分钟）",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        { "expr": "sum(rate(business_error_total[5m])) by (error_type) * 60", "legendFormat": "{{error_type}}" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "🏆 排行榜",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "title": "活跃用户 Top10（上传数）",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 23 },
      "targets": [{ "expr": "topk(10, sum(photo_upload_total) by (user_id))", "legendFormat": "{{user_id}}", "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "user_id": "用户ID", "Value": "上传数" } } }
      ]
    },
    {
      "title": "热门区域 Top10",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 23 },
      "targets": [{ "expr": "topk(10, sum(photo_upload_total) by (district))", "legendFormat": "{{district}}", "instant": true, "format": "table" }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "district": "区域", "Value": "上传数" } } }
      ]
    },
    {
      "title": "举报原因分布",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 23 },
      "targets": [{ "expr": "sum(report_submit_total) by (reason)", "legendFormat": "{{reason}}", "instant": true }]
    },
    {
      "title": "⚡ 性能监控",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "collapsed": false
    },
    {
      "title": "COS 上传耗时（P50/P90/P99）",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(cos_operation_duration_seconds_bucket{operation=\"upload\"}[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.9, sum(rate(cos_operation_duration_seconds_bucket{operation=\"upload\"}[5m])) by (le))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.99, sum(rate(cos_operation_duration_seconds_bucket{operation=\"upload\"}[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "照片上传耗时（P50/P90/P99）",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(photo_upload_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.9, sum(rate(photo_upload_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.99, sum(rate(photo_upload_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "COS 操作成功/失败",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "targets": [
        { "expr": "sum(rate(cos_operation_total{status=\"success\"}[5m])) by (operation) * 60", "legendFormat": "{{operation}}-成功" },
        { "expr": "sum(rate(cos_operation_total{status=\"error\"}[5m])) by (operation) * 60", "legendFormat": "{{operation}}-失败" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "登录统计",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "targets": [
        { "expr": "sum(rate(wechat_login_total{status=\"success\"}[5m])) * 60", "legendFormat": "微信登录-成功" },
        { "expr": "sum(rate(wechat_login_total{is_new_user=\"true\"}[5m])) * 60", "legendFormat": "新用户注册" },
        { "expr": "sum(rate(admin_login_total{status=\"success\"}[5m])) * 60", "legendFormat": "管理员登录-成功" },
        { "expr": "sum(rate(admin_login_total{status=\"fail\"}[5m])) * 60", "legendFormat": "管理员登录-失败" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "🛡️ 审核与处罚",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false
    },
    {
      "title": "举报处理统计",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 49 },
      "targets": [{ "expr": "sum(report_handle_total) by (result)", "legendFormat": "{{result}}", "instant": true }]
    },
    {
      "title": "举报对象类型分布",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 49 },
      "targets": [{ "expr": "sum(report_submit_total) by (target_type)", "legendFormat": "{{target_type}}", "instant": true }]
    },
    {
      "title": "用户处罚类型分布",
      "type": "piechart",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 49 },
      "targets": [{ "expr": "sum(user_punishment_total) by (punishment_type)", "legendFormat": "{{punishment_type}}", "instant": true }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["maptrace", "business"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "地图时迹 - 业务监控看板",
  "uid": "maptrace-business",
  "version": 1
}
